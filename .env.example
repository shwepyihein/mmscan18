# --- Required for app + API calls ---
# No trailing slash. If Nest uses setGlobalPrefix('api'), either append /api here OR set NEXT_PUBLIC_API_GLOBAL_PREFIX=api
NEXT_PUBLIC_API_URL=https://your-api.example.com
# NEXT_PUBLIC_API_GLOBAL_PREFIX=api

# Public URL of this Next.js site (HTTPS in production). Used for Telegram Login Widget
# redirect flow (`data-auth-url` → `/auth/telegram-callback`). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-frontend.example.com

# --- Auth (Better Auth proxy → backend) ---
# Prefer server-only key on the host (Vercel env, not NEXT_PUBLIC_*).
BETTER_AUTH_API_KEY=

# Optional fallback if your backend names the secret this way (bundled to client — avoid in prod).
NEXT_PUBLIC_TELEGRAM_TOKEN=

# Telegram Login Widget: bot @username from BotFather, without @
# Example: display name "Hot MM Manhwa Premium Bot" → username hotmmmanhwapremium_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=hotmmmanhwapremium_bot

# Optional overrides for Nest /auth/* routes (defaults match typical setup)
# TELEGRAM_BROWSER_LOGIN_PATH=/auth/telegram-login
# TELEGRAM_SYNC_PATH=/auth/telegram-login
# TELEGRAM_BROWSER_REGISTER_PATH=/auth/telegram-register
# TELEGRAM_USER_EXISTS_PATH=/auth/telegram-user-exists

# --- App ---
NEXT_PUBLIC_DEFAULT_CHAPTER_COIN_PRICE=5
