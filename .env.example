# --- Next.js site (public) ---
# No trailing slash. Used for Telegram Login Widget redirect and Better Auth base URL fallbacks.
# Must match the hostname users open in the browser (same host as in @BotFather → Configure Domain),
# or Telegram Login Widget shows "Bot domain invalid".
NEXT_PUBLIC_SITE_URL=https://your-frontend.example.com

# --- Nest / manhwa API (content, wallet) ---
# No trailing slash. If Nest uses setGlobalPrefix('api'), either append /api here OR set NEXT_PUBLIC_API_GLOBAL_PREFIX=api
NEXT_PUBLIC_API_URL=https://your-api.example.com
# NEXT_PUBLIC_API_GLOBAL_PREFIX=api

# --- Better Auth (this Next.js app) ---
# PostgreSQL connection string (Railway, Neon, local, etc.)
DATABASE_URL=postgres://user:password@host:5432/database
# openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin of this app (no trailing slash). Often same as NEXT_PUBLIC_SITE_URL.
BETTER_AUTH_URL=https://your-frontend.example.com
# Optional comma-separated extra origins for CORS (e.g. preview deployments)
# BETTER_AUTH_TRUSTED_ORIGINS=https://preview.example.com

# Server-side Telegram bot token (from @BotFather). Used to verify Login Widget + Mini App initData.
TELEGRAM_BOT_TOKEN=

# Telegram Login Widget: bot @username from BotFather, without @
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

# --- App ---
NEXT_PUBLIC_DEFAULT_CHAPTER_COIN_PRICE=5
