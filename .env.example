# Public API base (browser + Next API routes)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only: sent from Next.js API routes to your Nest/Better Auth backend (never NEXT_PUBLIC_*)
BETTER_AUTH_API_KEY=

# Optional: browser Telegram Login Widget bot username (no @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Optional: backend path for browser widget login (default /users/telegram-login)
# TELEGRAM_BROWSER_LOGIN_PATH=/users/telegram-login

NEXT_PUBLIC_DEFAULT_CHAPTER_COIN_PRICE=5
